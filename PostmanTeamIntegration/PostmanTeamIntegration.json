							"listen": "prerequest",
							"script": {
								"id": "71ca8b2e-920f-4f28-b564-2e0d02eb1c60",
								"exec": [
									"const text= Math.random().toString(36).substring(2)",
									"const email = text+\"@msn.com\"",
									"pm.environment.set(\"email\", email)  "
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"id": "4fa40d19-c4f2-4edb-85c0-4e681cfd8a89",
								"exec": [
									"const jsonResponse = pm.response.json();",
									"pm.collectionVariables.set(\"access_token\",jsonResponse.accessToken)",
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);})",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
